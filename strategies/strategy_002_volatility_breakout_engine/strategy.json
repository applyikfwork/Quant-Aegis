      "Volume >= 1.5x 20-period average",
      "ATR is increasing (expanding volatility)",
      "AI confidence >= 75%",
      "Wait 1 candle close confirmation (anti-fake-breakout)"
    ],
    "short": [
      "Price closes below Bollinger lower band",
      "Volume >= 1.5x 20-period average",
      "ATR is increasing (expanding volatility)",
      "AI confidence >= 75%",
      "Wait 1 candle close confirmation"
    ]
  },
  "exitRules": {
